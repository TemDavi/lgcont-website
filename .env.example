FLASK_SECRET_KEY=troque-por-uma-chave-secreta-forte
FLASK_APP=app.py
MYSQL_USER=root
MYSQL_PASSWORD=sua-senha-do-mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
