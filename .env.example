FLASK_SECRET_KEY=troque-por-uma-chave-secreta-forte
FLASK_APP=app.py
MYSQL_USER=root
MYSQL_PASSWORD=sua-senha-do-mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=site_contabilidade

# Endereco publico do site, usado para montar links enviados por e-mail.
PUBLIC_BASE_URL=https://seu-dominio.com

# Servidor SMTP. No Zoho, confira o host exato em Settings > Mail Accounts > SMTP.
# Contas Zoho gratuitas/organizacao free costumam usar smtp.zoho.com.
# Contas pagas no US DC podem usar smtppro.zoho.com.
MAIL_SERVER=smtp.zoho.com
MAIL_PORT=587
MAIL_USERNAME=avisos@seudominio.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_DEFAULT_SENDER=avisos@seudominio.com
MAIL_SUPPORT_EMAIL=contato@seudominio.com
COMPANY_NAME=LG Contabilidade
MAIL_USE_TLS=true
MAIL_USE_SSL=false
ACTIVATION_TOKEN_HOURS=24
